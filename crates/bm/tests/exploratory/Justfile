# Exploratory test execution recipes for sync, bridge & brain lifecycle
# Usage: just -f crates/bm/tests/exploratory/Justfile <phase>
# Full run: just -f crates/bm/tests/exploratory/Justfile all-no-lima
#
# Tests run on an isolated user account (TEST_USER@localhost) via SSH
# to prevent test cleanup from affecting the operator's home directory.
# This avoids destructive cleanup (rm -rf ~/.claude etc.) hitting the
# operator's real home. The test user's home is disposable.

set positional-arguments
set dotenv-load := false

# ─── Variables ─────────────────────────────────────────────────
# Local paths (operator machine — build + orchestration)
CARGO_ROOT := justfile_directory() + "/../../../.."
LOCAL_REPORT := justfile_directory() + "/REPORT.md"
LOCAL_PHASES := justfile_directory() + "/phases"
LOCAL_LIB := justfile_directory() + "/lib.sh"

# Remote test user (SSH-accessible, isolated home directory)
TEST_USER := "bm-test-user"
TEST_HOST := TEST_USER + "@localhost"

# Remote paths (test user machine — execution)
REMOTE_HOME := "/home/" + TEST_USER
REMOTE_BIN := REMOTE_HOME + "/.local/bin"
REMOTE_STAGING := REMOTE_HOME + "/.bm-exploratory-tests"
REMOTE_PHASES := REMOTE_STAGING + "/phases"
REMOTE_LIB := REMOTE_STAGING + "/lib.sh"
REMOTE_REPORT := REMOTE_STAGING + "/REPORT.md"
REMOTE_ENV := REMOTE_STAGING + "/env.sh"

# Test configuration
TEAM := "exploratory-test"
ORG := "devguyio-bot-squad"
REPO := "exploratory-test-team"
FULL_REPO := ORG + "/" + REPO
PROFILE := "scrum-compact"
BOARD := "Exploratory Test Board"
LIMA_VM := "lima-idem-test"
TUWUNEL_PORT := env("TUWUNEL_PORT", "8008")

# Remote paths derived from test user's HOME
REMOTE_TEAM_DIR := REMOTE_HOME + "/.botminter/workspaces/" + TEAM
REMOTE_TEAM_REPO := REMOTE_TEAM_DIR + "/team"

# ─── Setup ─────────────────────────────────────────────────────

# Build bm from source (local)
build:
    cd {{CARGO_ROOT}} && just build

# Full cleanup: stop processes, destroy containers/volumes, remove GitHub artifacts,
# clear keyring, wipe local config. Idempotent — safe to run repeatedly.
# Ensures a completely clean slate before deploy and test phases.
clean:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Cleaning test environment on {{TEST_HOST}}..."
    # Use Just variables directly (hardcoded into the script) instead of
    # sourcing env.sh, which may not exist on a cold start. This makes
    # clean reliable regardless of deploy state.
    ssh {{TEST_HOST}} 'bash -l -c "
        TEAM=\"{{TEAM}}\"
        ORG=\"{{ORG}}\"
        FULL_REPO=\"{{FULL_REPO}}\"
        BOARD=\"{{BOARD}}\"
        LIMA_VM=\"{{LIMA_VM}}\"
        source {{REMOTE_LIB}} 2>/dev/null || true

        # ── Processes ──
        # 1. Graceful stop via bm
        if [ -x {{REMOTE_BIN}}/bm ] && [ -f {{REMOTE_HOME}}/.botminter/config.yml ]; then
            {{REMOTE_BIN}}/bm stop --force --bridge -t $TEAM 2>/dev/null || true
        fi
        # 2. SIGTERM stale processes
        for pattern in \"[b]m brain-run\" \"[c]laude-code-acp-rs\" \"[c]laude.*stream-json\" \"[r]alph run\"; do
            for pid in \$(ps aux | grep \"\$pattern\" | awk \"{print \\\$2}\"); do
                kill \"\$pid\" 2>/dev/null || true
            done
        done
        sleep 1
        # 3. SIGKILL survivors
        for pattern in \"[b]m brain-run\" \"[c]laude-code-acp-rs\" \"[c]laude.*stream-json\" \"[r]alph run\"; do
            for pid in \$(ps aux | grep \"\$pattern\" | awk \"{print \\\$2}\"); do
                kill -9 \"\$pid\" 2>/dev/null || true
            done
        done

        # ── Container + Volume ──
        podman rm -f bm-tuwunel-$TEAM 2>/dev/null || true
        podman volume rm bm-tuwunel-$TEAM-data 2>/dev/null || true

        # ── GitHub ──
        gh repo delete $FULL_REPO --yes 2>/dev/null || true
        PROJ_NUM=\$(gh project list --owner $ORG --format json 2>/dev/null | jq -r \".projects[] | select(.title==\\\"$BOARD\\\") | .number\" 2>/dev/null)
        [ -n \"\$PROJ_NUM\" ] && gh project delete \"\$PROJ_NUM\" --owner $ORG --format json 2>/dev/null || true

        # ── Lima VM ──
        limactl delete --force $LIMA_VM 2>/dev/null || true

        # ── Keyring ──
        if type load_isolated_keyring &>/dev/null && load_isolated_keyring; then
            for u in superman-alice superman-bob superman-carol superman-dave bmadmin superman-pre-existing; do
                secret_tool clear service botminter.$TEAM.tuwunel username \$u 2>/dev/null || true
            done
            stop_isolated_keyring 2>/dev/null || true
        fi

        # ── Local state ──
        rm -rf ~/.botminter ~/.config/botminter 2>/dev/null || true
        rm -f {{REMOTE_BIN}}/bm {{REMOTE_BIN}}/bm-agent {{REMOTE_BIN}}/ralph {{REMOTE_BIN}}/claude {{REMOTE_BIN}}/claude-code-acp-rs

        # ── Port wait ──
        for i in \$(seq 1 10); do
            if ! ss -tlnp 2>/dev/null | grep -q \":{{TUWUNEL_PORT}} \"; then break; fi
            sleep 1
        done
    "' || true
    echo "Clean."

# Deploy binaries + test scripts to the remote test user
deploy: build clean
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Deploying to {{TEST_HOST}}..."
    # Create remote directories
    ssh {{TEST_HOST}} 'mkdir -p {{REMOTE_BIN}} {{REMOTE_PHASES}}'
    # Copy binaries (bm + bm-agent from build, others from operator's PATH)
    scp -q {{CARGO_ROOT}}/target/debug/bm {{TEST_HOST}}:{{REMOTE_BIN}}/bm
    scp -q {{CARGO_ROOT}}/target/debug/bm-agent {{TEST_HOST}}:{{REMOTE_BIN}}/bm-agent
    # Deploy ralph, claude, and claude-code-acp-rs from operator's PATH
    for bin in ralph claude claude-code-acp-rs; do
        LOCAL_BIN=$(which "$bin" 2>/dev/null || true)
        if [ -n "$LOCAL_BIN" ]; then
            scp -q "$LOCAL_BIN" {{TEST_HOST}}:{{REMOTE_BIN}}/"$bin"
        fi
    done
    # Copy test scripts
    scp -q "{{LOCAL_LIB}}" {{TEST_HOST}}:{{REMOTE_LIB}}
    scp -q {{LOCAL_PHASES}}/*.sh {{TEST_HOST}}:{{REMOTE_PHASES}}/
    ssh {{TEST_HOST}} 'chmod +x {{REMOTE_PHASES}}/*.sh'
    # Deploy GCP application default credentials for Vertex AI auth
    GCP_CREDS="$HOME/.config/gcloud/application_default_credentials.json"
    if [ -f "$GCP_CREDS" ]; then
        ssh {{TEST_HOST}} 'mkdir -p ~/.config/gcloud && rm -f ~/.config/gcloud/application_default_credentials.json'
        scp -q "$GCP_CREDS" {{TEST_HOST}}:~/.config/gcloud/application_default_credentials.json
    fi
    # Ensure git identity is configured (required for bm init)
    ssh {{TEST_HOST}} 'git config --global user.email 2>/dev/null || git config --global user.email "bm-test-user@botminter.dev"'
    ssh {{TEST_HOST}} 'git config --global user.name 2>/dev/null || git config --global user.name "BM Test User"'
    # Generate env.sh on the remote — sourced by run-phase before each phase
    printf '%s\n' \
        'export BM="{{REMOTE_BIN}}/bm"' \
        'export BM_AGENT="{{REMOTE_BIN}}/bm-agent"' \
        'export TEAM="{{TEAM}}"' \
        'export ORG="{{ORG}}"' \
        'export REPO="{{REPO}}"' \
        'export FULL_REPO="{{FULL_REPO}}"' \
        'export PROFILE="{{PROFILE}}"' \
        'export BOARD="{{BOARD}}"' \
        'export TEAM_DIR="{{REMOTE_TEAM_DIR}}"' \
        'export TEAM_REPO="{{REMOTE_TEAM_REPO}}"' \
        'export REPORT="{{REMOTE_REPORT}}"' \
        'export LIMA_VM="{{LIMA_VM}}"' \
        'export LIB="{{REMOTE_LIB}}"' \
        'export CARGO_ROOT="{{REMOTE_STAGING}}"' \
        'export TUWUNEL_PORT="{{TUWUNEL_PORT}}"' \
        'export PATH="{{REMOTE_BIN}}:$PATH"' \
        | ssh {{TEST_HOST}} 'cat > {{REMOTE_ENV}}'
    echo "Deploy complete."


# Initialize report file on remote
init-report:
    #!/usr/bin/env bash
    ssh {{TEST_HOST}} 'bash -l -c "source {{REMOTE_ENV}} && \
        BM_VERSION=\$(\$BM --version 2>/dev/null || echo unknown) && \
        LIMA_VERSION=\$(limactl --version 2>/dev/null | head -1 || echo unknown) && \
        GH_USER=\$(gh api user --jq .login 2>/dev/null || echo unknown) && \
        printf \"%s\n\" \
            \"# Exploratory Test Report: Sync, Bridge & Lima Idempotency\" \
            \"\" \
            \"**Date:** \$(date +%Y-%m-%d)\" \
            \"**Build:** \$BM_VERSION (local debug)\" \
            \"**Environment:** \$(uname -sm), podman rootless, limactl \$LIMA_VERSION, gh (\$GH_USER)\" \
            \"**Test User:** {{TEST_USER}}@localhost (isolated)\" \
            \"\" \
            \"## Results\" \
            > \$REPORT"'

# Fetch report from remote to local
fetch-report:
    scp -q {{TEST_HOST}}:{{REMOTE_REPORT}} "{{LOCAL_REPORT}}" 2>/dev/null || echo "No report to fetch."

# ─── Keyring ───────────────────────────────────────────────────

# Idempotent: starts isolated keyring on remote if not running, reuses if alive
ensure-keyring:
    ssh {{TEST_HOST}} 'bash -l -c "source {{REMOTE_ENV}} && source {{REMOTE_LIB}} && ensure_keyring"'

# ─── Preflight ─────────────────────────────────────────────────

# Pre-flight check: verify remote environment is ready
preflight: ensure-keyring
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Pre-flight checks on {{TEST_HOST}}..."
    ssh {{TEST_HOST}} 'bash -l -c "source {{REMOTE_ENV}} && source {{REMOTE_LIB}} && \
        set -euo pipefail && \
        if ss -tlnp sport = :\$TUWUNEL_PORT 2>/dev/null | grep -q LISTEN; then \
            echo \"FATAL: Port \$TUWUNEL_PORT is in use\"; exit 1; \
        fi && \
        echo \"  ✓ Port \$TUWUNEL_PORT is free\" && \
        if load_isolated_keyring; then \
            echo \"  ✓ Isolated keyring running (pid=\$ISOLATED_DBUS_PID)\"; \
        else \
            echo \"FATAL: Isolated keyring not running\"; exit 1; \
        fi && \
        for tool in podman just gh curl jq; do \
            command -v \$tool >/dev/null 2>&1 || { echo \"FATAL: \$tool not found\"; exit 1; }; \
        done && \
        echo \"  ✓ All required tools available\" && \
        for bin in \$BM \$BM_AGENT; do \
            [ -x \$bin ] || { echo \"FATAL: \$bin not executable (run just deploy)\"; exit 1; }; \
        done && \
        echo \"  ✓ bm + bm-agent deployed\" && \
        gh auth status >/dev/null 2>&1 || { echo \"FATAL: gh not authenticated on {{TEST_USER}}\"; exit 1; } && \
        echo \"  ✓ gh authenticated\" && \
        CLAUDE_RESP=\$(echo \"say ok\" | claude --print --bare 2>&1) && \
        if echo \"\$CLAUDE_RESP\" | grep -qi \"ok\"; then \
            echo \"  ✓ Claude smoke test passed\"; \
        else \
            echo \"FATAL: Claude smoke test failed: \$CLAUDE_RESP\"; exit 1; \
        fi && \
        echo \"Pre-flight OK.\""'

# ─── Phase recipes ─────────────────────────────────────────────
# Each phase runs on the remote test user via SSH.
# env.sh provides all configuration; the phase script runs in a login shell.

[private]
run-phase phase timeout="300":
    timeout --signal=TERM --kill-after=15 {{timeout}} ssh {{TEST_HOST}} 'bash -l -c "source {{REMOTE_ENV}} && exec {{REMOTE_PHASES}}/{{phase}}"'

phase-a: init-report (run-phase "phase-a.sh" "600")

phase-b: ensure-keyring (run-phase "phase-b.sh")

phase-c: ensure-keyring (run-phase "phase-c.sh")

phase-d: ensure-keyring (run-phase "phase-d.sh")

phase-e: ensure-keyring (run-phase "phase-e.sh")

phase-f: ensure-keyring (run-phase "phase-f.sh")

phase-g: (run-phase "phase-g.sh")

phase-h: ensure-keyring (run-phase "phase-h.sh" "1200")

# Isolated ACP diagnostic test (requires team to exist — run after phase-e)
phase-acp-isolated: ensure-keyring (run-phase "phase-acp-isolated.sh" "600")

# ─── Orchestration ─────────────────────────────────────────────

# Run all phases except Lima (B through H)
# Starts and ends with clean to ensure a known-good state.
all-no-lima: clean deploy preflight init-report phase-b phase-c phase-d phase-e phase-f phase-h phase-g fetch-report clean

# Run all phases including Lima VM test
# Starts with clean; phase-a creates+destroys its own team; clean between A and B resets for the main phases; ends with clean.
all: clean deploy preflight init-report phase-a clean deploy preflight init-report phase-b phase-c phase-d phase-e phase-f phase-h phase-g fetch-report clean

# Run only bridge + workspace phases (skip init, assume team exists)
bridge-and-workspace: ensure-keyring phase-c phase-d phase-e
