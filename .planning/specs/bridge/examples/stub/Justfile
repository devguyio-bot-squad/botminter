# Stub/no-op bridge implementation -- conformance test fixture
# All recipes exit 0 and produce minimal valid output

start:
    @mkdir -p "$BRIDGE_CONFIG_DIR"
    @echo '{"service_url": "http://localhost:0", "admin_user_id": "stub-admin", "status": "stub"}' > "$BRIDGE_CONFIG_DIR/config.json"

stop:
    @echo "stub: stop (no-op)" >&2

health:
    @echo "stub: healthy" >&2

onboard username:
    @mkdir -p "$BRIDGE_CONFIG_DIR"
    @echo '{"username": "{{username}}", "user_id": "stub-id", "token": "stub-token"}' > "$BRIDGE_CONFIG_DIR/config.json"

rotate username:
    @mkdir -p "$BRIDGE_CONFIG_DIR"
    @echo '{"username": "{{username}}", "user_id": "stub-id", "token": "rotated-stub-token"}' > "$BRIDGE_CONFIG_DIR/config.json"

verify username:
    @echo "stub: verified {{username}}" >&2

remove username:
    @echo "stub: removed {{username}}" >&2

room-create name:
    @mkdir -p "$BRIDGE_CONFIG_DIR"
    @echo '{"name": "{{name}}", "room_id": "stub-room-id"}' > "$BRIDGE_CONFIG_DIR/config.json"

room-list:
    @mkdir -p "$BRIDGE_CONFIG_DIR"
    @echo '{"rooms": [{"name": "general", "room_id": "stub-room-id"}]}' > "$BRIDGE_CONFIG_DIR/config.json"
